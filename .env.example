# ---- Django ----
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Default is SQLite (no config needed). For the proposal's pgvector path:
# DATABASE_URL=postgres://user:pass@localhost:5432/rfpauthor
# USE_PGVECTOR=true

# ---- LLM gateway: OpenAI ----
# Provider-agnostic. Set LLM_PROVIDER=mock to run fully offline (no key/network).
LLM_PROVIDER=openai            # openai | mock
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: point at an OpenAI-compatible / Azure-OpenAI base URL.
# OPENAI_BASE_URL=
